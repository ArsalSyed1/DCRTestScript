{
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test:split": "concurrently \"npm run test:testing1\" \"npm run test:testing3\" \"npm run test:testing4\" \"npm run test:AdministrationTestCases\" \"npm run test:communityOrganizationTestCases\" \"npm run test:designer_AppsTab\" \"npm run test:designer_HelpTab\" \"npm run test:designer_menu&insertTab\" \"npm run test:designer_SimulationTab\" \"npm run test:graphRelatedTestCases\" \"npm run test:Verify-all-testcase.cy.js\"",
    "test:AdministrationTestCases": "cypress run --spec 'cypress/e2e/runner/AdministrationTestCases.cy.js'",
    "test:communityOrganizationTestCases": "cypress run --spec 'cypress/e2e/runner/communityOrganizationTestCases.cy.js'",
    "test:designer_AppsTab": "cypress run --spec 'cypress/e2e/runner/designer_AppsTab.cy.js'",
    "test:designer_HelpTab": "cypress run --spec 'cypress/e2e/runner/designer_HelpTab.cy.js'",
    "test:designer_menu&insertTab": "cypress run --spec 'cypress/e2e/runner/designer_menu&insertTab.cy.js'",
    "test:designer_SimulationTab": "cypress run --spec 'cypress/e2e/runner/designer_SimulationTab.cy.js'",
    "test:graphRelatedTestCases": "cypress run --spec 'cypress/e2e/runner/graphRelatedTestCases.cy.js'",
    "test:testing1": "cypress run --spec 'cypress/e2e/runner/testing1.cy.js'",
    "test:testing3": "cypress run --spec 'cypress/e2e/runner/testing3.cy.js'",
    "test:testing4": "cypress run --spec 'cypress/e2e/runner/testing4.cy.js'",
    "test:Verify-all-testcase.cy.js": "cypress run --spec 'cypress/e2e/runner/Verify-all-testcase.cy.js'",
    "cy:parallel": "cross-env NODE_OPTIONS='--max-old-space-size=6144' cypress-parallel -d cypress/e2e/runner/ -t 4 -s test --headless --browser chrome --disable-gpu --no-sandbox --disable-dev-shm-usage",
    "cy:parallel:prodIIS02": "cypress-parallel -d cypress/e2e/runner/ -t 5 -s cy_run_prodIIS02 --headless --disable-gpu --no-sandbox --disable-dev-shm-usage",
    "cy:parallel:demo": "cypress-parallel -d cypress/e2e/runner/ -t 4 -s cy:run_demo --headless --disable-gpu --no-sandbox --disable-dev-shm-usage",
    "test": "npx cypress run ",
    "generate-report": "node generate-report.js",
    "cy:run_test": "npx cypress run --env ENV=test",
    "cy_run_prodIIS01": "npx cypress run --env ENV=prodIIS01",
    "cy_run_prodIIS02": "npx cypress run --env ENV=prodIIS02",
    "cy:run_demo": "npx cypress run --env ENV=demo",
    "report:merge": "mochawesome-merge cypress/reports/mochawesome-report/*.json > cypress/reports/mochawesome.json",
    "merge-report": "npx mochawesome-merge ./cypress/reports/*.json > merged-report.json && npx marge merged-report.json",
    "report:generate": "marge cypress/reports/mochawesome.json -f report -o cypress/reports/mochawesome-html-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:run": "npx cypress run --spec && npm run allure:generate && npm run allure:open",
    "allure:pipelines": "npx cypress run && npm run allure:generate",
    "allure:pipeline": "npx cypress run --spec cypress/e2e/runner/designer_AppsTab.cy.js && npm run allure:generate"
  },
  "author": "uzair",
  "license": "ISC",
  "devDependencies": {
    "@4tw/cypress-drag-drop": "^2.2.5",
    "@shelex/cypress-allure-plugin": "^2.41.2",
    "allure-commandline": "^2.34.1",
    "allure-cypress": "^3.3.0",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "cypress": "^15.8.1",
    "cypress-drag-drop": "^1.1.1",
    "cypress-file-upload": "^5.0.8",
    "cypress-log-to-output": "^1.1.2",
    "cypress-mochawesome-reporter": "^3.8.2",
    "cypress-multi-reporters": "^2.0.4",
    "cypress-split": "^1.24.18",
    "cypress-terminal-report": "^7.2.1",
    "cypress-xpath": "^2.0.1",
    "junit-merge": "^2.0.0",
    "mocha": "^11.0.1",
    "mocha-junit-reporter": "^2.2.1",
    "mocha-multi-reporters": "^1.5.1",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0",
    "xml2js": "^0.6.2"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "cypress-parallel": "^0.15.0",
    "cypress-real-events": "^1.13.0",
    "docx": "^9.1.1",
    "dotenv": "^16.4.7",
    "gaxios": "^6.7.1",
    "googleapis": "^144.0.0",
    "mammoth": "^1.8.0",
    "nodemailer": "^7.0.5",
    "tar": "^7.4.3",
    "uuid": "^11.1.0",
    "xmldom": "^0.6.0"
  },
  "e2e": {
    "testFiles": "**/*.spec.js",
    "watchForFileChanges": false
  }
}
